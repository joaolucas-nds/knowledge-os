# Copie para .env.local (convenção Next.js) — nunca commitar o .env.local real.

# URL do apps/api em dev. Em produção, apontar para o domínio real da API.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Supabase ──────────────────────────────────────────────────────────────────
# Encontre em: painel do Supabase → Project Settings → API (aba "API Keys")
#
# URL do projeto (ex.: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
#
# Publishable key — segura para expor no browser (limita acesso via Row Level
# Security). No painel: aba "API Keys" → "Publishable key".
# Antes de 2026, chamava-se "anon key" — se o seu projeto for antigo, use
# NEXT_PUBLIC_SUPABASE_ANON_KEY e ajuste lib/supabase/client.ts e server.ts.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXX
