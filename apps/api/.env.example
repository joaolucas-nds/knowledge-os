# Copie para .env e ajuste (nunca commitar o .env real).

PORT=3001
HOST=0.0.0.0

# Separe múltiplas origens por vírgula. "*" libera tudo (só em dev local).
CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Opcional nesta F0 — se ausente, a API sobe sem banco e /health/db
# responde 503 "not_configured" (comportamento esperado, não é erro).
#
# Connection string do Postgres do Supabase — MESMA URL de
# packages/db/.env.example (modo Session, porta 5432). Ver o comentário
# detalhado lá sobre por que Session mode e não Transaction mode (6543).
DATABASE_URL="postgresql://postgres.SEU-PROJETO:SUA-SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres"

# JWT Secret do projeto Supabase (Project Settings → API → JWT Settings →
# "Legacy JWT Secret" — clique em "Reveal" se estiver oculto). Ausente =
# rotas que exigem login (ex.: /me) retornam 503 "auth_not_configured".
SUPABASE_JWT_SECRET=""
